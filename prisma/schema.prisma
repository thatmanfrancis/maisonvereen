// Maison Vereen — Prisma 7 Schema
// NOTE: datasource url is NOT set here in Prisma 7 — it lives in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Application — full form from DOC-20260617-WA0002 ─────────────────────────
model Application {
  id            String            @id @default(cuid())
  name          String
  email         String
  phone         String?
  country       String
  whatYouDo     String
  howHeard      String            @default("Not specified")
  referredBy    String?
  whatMadeApply String            @db.Text
  earlyThing    String?           @db.Text
  anythingElse  String?           @db.Text
  consent       Boolean           @default(true)
  status        ApplicationStatus @default(PENDING)
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// ── Waitlist — email + name + country entry from Waitlist page ───────────────
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  country   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ── Admin users ───────────────────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash — never store plain text
  name      String
  createdAt DateTime @default(now())
}

// ── Notification Emails — custom recipients managed by admins ───────────────
model NotificationEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}
